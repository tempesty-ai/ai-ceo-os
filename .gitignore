.claude/agent-memory/
.claude/worktrees/
.claude/logs/
.claude/hooks/
.claude/*.local.*

# Build & Runtime
node_modules/
.next/
.venv/
__pycache__/
*.pyc
.tmp/

# OS Files
.DS_Store
Thumbs.db
@eaDir/

# IDE
.vscode/
.idea/
